<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <delivery_restriction>

            <general>
                <enabled>1</enabled>
                <use_db_zipcodes>0</use_db_zipcodes>
                <restriction_type>blacklist</restriction_type>
                <zip_codes></zip_codes>
                <error_message>Delivery is not available to your zip code.</error_message>
            </general>

            <customer_groups>
                <enabled>0</enabled>
                <group_ids></group_ids>
            </customer_groups>

            <product_page>
                <enabled>1</enabled>
                <widget_title>Check Delivery Availability</widget_title>
                <available_message>Great news! Delivery is available to your area.</available_message>
                <unavailable_message>Sorry, delivery is not available to your zip code.</unavailable_message>
                <input_placeholder>Enter ZIP / Postal Code</input_placeholder>
            </product_page>

            <delivery_estimate>
                <enabled>1</enabled>
                <min_days>3</min_days>
                <max_days>7</max_days>
            </delivery_estimate>

            <checkout>
                <block_order>1</block_order>
                <checkout_error_message>We cannot process your order. Delivery is not available to zip code: %1. Please update your shipping address.</checkout_error_message>
            </checkout>

            <email>
                <enabled>0</enabled>
                <sender>general</sender>
                <recipient></recipient>
                <cc></cc>
            </email>

            <logging>
                <enabled>0</enabled>
            </logging>

        </delivery_restriction>
    </default>
</config>
